{
  "name": "internal-portal-desktop",
  "version": "1.0.0",
  "description": "Desktop app for Internal portal (pointing tomy.programisto.fr)",
  "main": "src/main.js",
  "private": true,
  "author": "Programisto <tech@programisto.fr>",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:signed": "CSC_IDENTITY_AUTO_DISCOVERY=true electron-builder --mac",
    "build:mac:signed:keychain": "CSC_IDENTITY_AUTO_DISCOVERY=true CSC_KEYCHAIN=$HOME/Library/Keychains/login.keychain-db electron-builder --mac",
    "build:mac:p12": "CSC_LINK=\"$(pwd)/Certificates.p12\" electron-builder --mac",
    "test:quarantine": "bash scripts/test-quarantine.sh",
    "debug:signing": "bash scripts/debug-signing.sh",
    "fix:quarantine": "bash scripts/fix-quarantine.sh",
    "install:mac": "bash scripts/install-from-dmg.sh",
    "build:mac:internal": "bash scripts/build-and-package.sh",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@electron/osx-sign": "^2.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "fr.programisto.internal-portal",
    "productName": "Internal Portal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon-white-nobg.png",
      "build/icon-black.png"
    ],
    "mac": {
      "icon": "build/icon-white-nobg.png",
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon-white-nobg.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon-white-nobg.png",
      "category": "Office"
    }
  }
}
