{
  "name": "internal-portal-desktop",
  "version": "1.0.0",
  "description": "Desktop app for Internal portal (pointing tomy.programisto.fr)",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "fr.programisto.internal-portal",
    "productName": "Internal Portal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon-white-nobg.png",
      "build/icon-black.png"
    ],
    "mac": {
      "icon": "build/icon-white-nobg.png",
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon-white-nobg.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon-white-nobg.png",
      "category": "Office"
    }
  }
}