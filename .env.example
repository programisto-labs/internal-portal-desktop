# macOS notarization (optional)
# Get app-specific password at https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
# Optional if you have multiple teams
APPLE_TEAM_ID=

# macOS signing with .p12 (when using npm run build:mac:p12). Certificates.p12 must exist in project root.
# Do not commit the password.
CSC_KEY_PASSWORD=
